{
  "name": "monad-falcon-cv-bridge",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "scripts": {
    "clean": "rm -rf artifacts cache",
    "compile": "$npm_execpath run compile:hardhat",
    "compile:hardhat": "hardhat compile",
    "deploy:all": "hardhat run script/deployAndWire.ts --network ethereum",
    "wire:all": "hardhat run script/wireConfig.ts --network ethereum",
    "verify:all": "ts-node script/verifyDeployed.ts",
    "verify:ethereum": "ts-node script/verifyDeployed.ts ethereum",
    "verify:monad": "ts-node script/verifyDeployed.ts monad",
    "lint": "$npm_execpath run lint:js && $npm_execpath run lint:sol",
    "lint:fix": "eslint --fix '**/*.{js,ts,json}' && prettier --write . && solhint 'contracts/**/*.sol' --fix --noPrompt",
    "lint:js": "eslint '**/*.{js,ts,json}' && prettier --check .",
    "lint:sol": "solhint 'contracts/**/*.sol'",
    "test": "$npm_execpath run test:hardhat",
    "test:hardhat": "hardhat test"
  },
  "resolutions": {
    "ethers": "^5.7.2",
    "hardhat-deploy": "^0.12.1"
  },
