#
#               Example environment configuration
#
#   .-.-.   .-.-.   .-.-.   .-.-.   .-.-.   .-.-.   .-.-.   .-.-
#  / / \ \ / / \ \ / / \ \ / / \ \ / / \ \ / / \ \ / / \ \ / / \
# `-'   `-`-'   `-`-'   `-`-'   `-`-'   `-`-'   `-`-'   `-`-'

# Required for the Ledger-based deploy-and-wire flow
LEDGER_ADDRESS=
LEDGER_DERIVATION_PATH=m/44'/60'/0'/0/0

# Optional: only needed for raw Hardhat tasks that expect a software signer.
# The deploy:all script does not use these values.
MNEMONIC=
PRIVATE_KEY=

# RPC endpoints for the two production networks used by this bridge
RPC_URL_ETHEREUM=
RPC_URL_MONAD=

# Required for source verification on Etherscan and MonadScan.
ETHERSCAN_API_KEY=

# Optional: override the default owner/delegate used during deployment.
# Defaults to LEDGER_ADDRESS when unset.
BRIDGE_OWNER=